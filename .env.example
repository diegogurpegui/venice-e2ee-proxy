# Required: Your Venice AI API key
VENICE_API_KEY=your-venice-api-key-here

# Optional overrides (these override config.yaml values)
# PORT=3000
# HOST=127.0.0.1
# VENICE_BASE_URL=https://api.venice.ai
# VERIFY_ATTESTATION=true
# ENABLE_DCAP=true
# SESSION_TTL=1800000
# LOG_LEVEL=info
# ENDPOINT_PASSTHRU=false
# Docker build only (see docker-compose.yml): omit or use main for latest; set to a commit SHA to pin.
# VENICE_PROXY_REF=main
